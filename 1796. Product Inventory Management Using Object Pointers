#include <iostream>
#include <string>
#include <iomanip>
using namespace std;
class Product {
private:
 string productName;
 int productID;
 double price;
 int quantity;
public:
 void setDetails(string name, int id, double p, int q) {
 productName = name;
productID = id;
 price = p;
 quantity = q;
 }
 double calculateTotalValue() {
 return price * quantity;
 }
 void display() {
 cout << "Product Name: " << productName << endl;
 cout << "Product ID: " << productID << endl;
 cout << "Price: " << fixed << setprecision(2) << price << endl;
 cout << "Quantity: " << quantity << endl;
 cout << "Total Value: " << fixed << setprecision(2) << calculateTotalValue() << endl;
 }
};
int main() {
 string name;
 int id, qty;
 double price;
 if (cin >> name >> id >> price >> qty) {

 Product* productPtr = new Product();
 productPtr->setDetails(name, id, price, qty);
 productPtr->display();
 delete productPtr;
 }
 return 0;
}
