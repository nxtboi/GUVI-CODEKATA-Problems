#include <iostream>
#include <iomanip>
using namespace std;
class Box {
private:
 double length, breadth, height;
public:
 // Overloaded function: For cuboid (3 dimensions)
 void setDimensions(double l, double b, double h) {
 length = l;
 breadth = b;
 height = h;
 }
// Overloaded function: For cube (1 dimension)
 void setDimensions(double side) {
 length = breadth = height = side;
 }
 double calculateVolume() {
 return length * breadth * height;
 }
 // Declaration of friend function
 friend void compareBoxes(Box b1, Box b2);
};
// Friend function definition
void compareBoxes(Box b1, Box b2) {
 double vol1 = b1.calculateVolume();
 double vol2 = b2.calculateVolume();
 if (vol1 > vol2) {
 cout << "Box 1 is larger" << endl;
 } else if (vol2 > vol1) {
 cout << "Box 2 is larger" << endl;
 } else {
 cout << "Both boxes are equal in volume" << endl;
 }
}
int main() {
 Box box1, box2;
 int type;
 double l, b, h, s;
 // Process Box 1
 if (!(cin >> type)) return 0;
 if (type == 1) {
 cin >> l >> b >> h;
 box1.setDimensions(l, b, h);
 } else {
 cin >> s;
 box1.setDimensions(s);
 }
 // Process Box 2
 if (!(cin >> type)) return 0;
 if (type == 1) {
 cin >> l >> b >> h;
 box2.setDimensions(l, b, h);
 } else {
 cin >> s;
 box2.setDimensions(s);
 }
 // Output volumes with 2 decimal precision
 cout << fixed << setprecision(2);
 cout << "Volume of Box 1: " << box1.calculateVolume() << endl;
 cout << "Volume of Box 2: " << box2.calculateVolume() << endl;
 // Call friend function for comparison
 compareBoxes(box1, box2);
 return 0;
}
