#include <iostream>
#include <iomanip>
using namespace std;
class Sensor {
private:
 int sensorID;
 double temperature;
 static int totalSensors;
public:
 Sensor(int id, double temp) {
 sensorID = id;
 temperature = temp;
 totalSensors++;
 }
 void updateTemperature(double temp) {
 temperature = temp;
 }
 double getTemperature() const volatile {
 return temperature;
 }
 static int getTotalSensors() {
 return totalSensors;
 }
};
