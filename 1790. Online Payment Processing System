#include <iostream>
#include <iomanip>
#include <vector>
using namespace std;
class Payment {
private:
 double amount;
public:
 Payment(double amt) : amount(amt) {}
 double getAmount() {
 return amount;
 }
 virtual double calculateFinalAmount() = 0;
 virtual ~Payment() {}
};
class CreditCard : public Payment {
public:
 CreditCard(double amt) : Payment(amt) {}
 double calculateFinalAmount() override {
 return getAmount() + (getAmount() * 0.02);
 }
};
class UPI : public Payment {
public:
 UPI(double amt) : Payment(amt) {}
 double calculateFinalAmount() override {
 return getAmount() + (getAmount() * 0.005);
 }
};
class NetBanking : public Payment {
public:
 NetBanking(double amt) : Payment(amt) {}
 double calculateFinalAmount() override {
 return getAmount() + 10.0;
 }
};
int main() {
 int n;
 if (!(cin >> n)) return 0;
 double totalProcessedAmount = 0.0;

 cout << fixed << setprecision(2);
 for (int i = 0; i < n; i++) {
 int type;
 double amt;
 cin >> type >> amt;
 Payment* p = nullptr;
 if (type == 1) {
 p = new CreditCard(amt);
 } else if (type == 2) {
 p = new UPI(amt);
 } else if (type == 3) {
 p = new NetBanking(amt);
 }
 if (p != nullptr) {
 double finalAmt = p->calculateFinalAmount();
 cout << "Final Amount: " << finalAmt << endl;
 totalProcessedAmount += finalAmt;

 delete p;
 }
 }
 cout << "Total Processed Amount: " << totalProcessedAmount << endl;
 return 0;
}
