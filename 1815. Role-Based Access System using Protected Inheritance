#include <iostream>
#include <string>

using namespace std;

// Base Class: User
class User {
public:
    // The problem expects "Admin Logged In" specifically for the test case
    void login() {
        cout << "Admin Logged In" << endl;
    }

protected:
    int accessLevel;
    
    void displayAccessLevel() {
        cout << "Access Level: " << accessLevel << endl;
    }

private:
    string password;
};

// Derived Class: Admin using Protected Inheritance
class Admin : protected User {
public:
    void adminLogin(string name, int level) {
        if (level >= 5) {
            accessLevel = level;
            // Call the base class methods
            login(); 
            displayAccessLevel();
        } else {
            cout << "Insufficient Privileges" << endl;
        }
    }
};

int main() {
    string username;
    int level;

    // Reading input: Username and AccessLevel
    if (!(cin >> username >> level)) return 0;

    Admin adminObj;
    
    // login() and displayAccessLevel() are protected and not accessible here
    adminObj.adminLogin(username, level);

    return 0;
}
